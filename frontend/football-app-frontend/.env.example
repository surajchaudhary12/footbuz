# Frontend API Configuration
# Update this with your actual backend URL for production/staging deployments

# Local development - backend running on localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Production - replace with your actual Render backend URL
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api

# Staging/Development alternatives
# NEXT_PUBLIC_API_BASE_URL=https://your-staging-backend.onrender.com/api
