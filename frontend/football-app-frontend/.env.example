# Frontend API Configuration
# Update this with your actual backend URL for production/staging deployments

# Local development - backend running on localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Production - replace with your actual Render backend URL
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com

# Staging/Development alternatives
# NEXT_PUBLIC_API_BASE_URL=https://your-staging-backend.onrender.com

# Google OAuth client ID used by Google Sign-In button
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
