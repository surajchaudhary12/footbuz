# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000

# MongoDB Configuration
# Use MongoDB Atlas or local MongoDB instance
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name
# Legacy alternative (deprecated, prefer MONGODB_URI)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database-name

# Frontend URLs for CORS (comma-separated or individual env vars)
# Local development
FRONTEND_URL=http://localhost:3000

# Production/Staging
# FRONTEND_URL=https://your-frontend.vercel.app

# External API Keys
# Football-Data.org API (https://www.football-data.org/)
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_KEY1=your_api_key_here
API_FOOTBALL_KEY2=your_api_key_here

# RapidAPI Key (for additional sports APIs)
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Application Environment
NODE_ENV=development
# NODE_ENV=production

# JWT Authentication
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth (for /api/auth/google)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
